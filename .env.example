# Copy to ".env" and fill from your InsForge dashboard (https://insforge.dev).
# When VITE_INSFORGE_BASE_URL is set, the app uses InsForge auth + Postgres tables
# from insforge-schema.sql instead of the local Express API.

VITE_INSFORGE_BASE_URL=https://YOUR_APP_KEY.YOUR_REGION.insforge.app
VITE_INSFORGE_ANON_KEY=your_public_anon_key

# --- Local Express API + admin panel (when not using InsForge for auth) ---
JWT_SECRET=change-me-to-a-long-random-string
# First deploy: promote this email to role "admin" on server start (must match an existing user).
ADMIN_BOOTSTRAP_EMAIL=you@example.com
# Optional: lock CORS to your web origin (otherwise all origins are allowed).
# CORS_ORIGIN=https://yourdomain.com
# AUTH_RATE_LIMIT_MAX=120

# Optional: chat client (Vite) when API is not same-origin (e.g. vite preview on 4173 only).
# VITE_API_BASE_URL=http://localhost:3000
# VITE_SOCKET_URL=http://localhost:3000

# EdgeOne Pages (and any static CDN build): set in the hosting UI so Vite bakes them into the bundle.
# VITE_API_BASE_URL=https://your-api.example.com
# VITE_SOCKET_URL=https://your-api.example.com
